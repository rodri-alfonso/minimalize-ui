{
	"$schema": "https://json.schemastore.org/swcrc",
	"jsc": {
		"parser": {
			"syntax": "typescript",
			"tsx": true
		},
		"transform": {
			"react": {
				"runtime": "automatic"
			}
		},
		"target": "es2020",
		"loose": true,
		"externalHelpers": true,
		"keepClassNames": false
	},
	"minify": true
}
